# Copy to .env locally if your tooling loads it.
#
# Frontend (Expo) reads EXPO_PUBLIC_* at bundle time.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_ANALYTICS_ENABLED=0
# EXPO_PUBLIC_SENTRY_DSN=

# Backend API (Django)
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006
DATABASE_URL=postgresql://lunabms:lunabms@localhost:5432/lunabms

# SMTP / email verification
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
# e.g. http://localhost:8081/verify-email
DJANGO_AUTH_VERIFY_EMAIL_URL=


